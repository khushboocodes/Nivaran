# Local Postgres started by docker-compose at the project root.
DATABASE_URL="postgresql://nivaran:nivaran@localhost:5432/nivaran?schema=public"
PORT=3001

SESSION_SECRET="dev-only-replace-me-with-32-bytes-base64"
SESSION_COOKIE_NAME="nivaran_session"
SESSION_TTL_HOURS=168
PUBLIC_APP_URL="http://localhost:3000"

# Optional. When set, complaint classification uses OpenAI's chat completions
# instead of the keyword heuristic. Falls back transparently on errors.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=openai

# Email notifications. When SMTP_HOST is unset the server logs
# emails to stdout instead of sending — keeps the prototype runnable without
# an SMTP account. Recommended free providers: Mailtrap (sandbox testing),
# Resend (3k/month free), Brevo (300/day free), or Gmail with an App Password.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASSWORD=re_********
# SMTP_FROM="Nivaran <noreply@yourdomain.com>"

# S3-compatible object storage for attachments. Defaults match
# the MinIO container in docker-compose.yml. To deploy with Cloudflare R2
# (10 GB free tier, no egress fees) replace ENDPOINT/keys/bucket and set
# S3_PUBLIC_URL to the R2 public bucket URL.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=nivaran
S3_SECRET_KEY=nivaran-dev-only
S3_BUCKET=nivaran-attachments
S3_PUBLIC_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# SMS notifications. Default 'console' just logs every send to
# stdout — zero cost, perfect for the prototype. Set SMS_PROVIDER=twilio
# (or msg91 / sns) when payment is approved; the call sites do not change.
SMS_PROVIDER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
